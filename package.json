{
  "name": "markdown-pdf-renderer-cross-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Electron + Chromium rewrite of MarkdownPDFRenderer",
  "author": "sean9112",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "clean": "node ./Scripts/clean.mjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 1420\" \"wait-on http://127.0.0.1:1420 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:1420 electron .\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:mac": "npm run build && electron-builder --mac zip",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.sean9112.markdownpdfrendererx",
    "productName": "Markdown PDF Renderer",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "icon": "buildResources/icon.png",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "icon": "buildResources/icon.png"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "buildResources/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "buildResources/icon.png"
    }
  }
}
